#!/usr/bin/expect -f
# 02_room_walk.exp — Test room connectivity via DFS walking
# Walks all reachable rooms from the starting room using movement commands,
# verifies exits work, and reports unreachable rooms.

set script_dir [file dirname [file normalize [info script]]]
source "$script_dir/../lib/mud_connect.exp"
source "$script_dir/../lib/helpers.exp"

if {$argc < 2} {
    puts "Usage: expect 02_room_walk.exp <host> <port> \[report_file\]"
    exit 1
}

set host [lindex $argv 0]
set port [lindex $argv 1]
set report_file [expr {$argc >= 3 ? [lindex $argv 2] : ""}]

set test_user "qatest"
set test_pass "testpass123"

# Starting room — player's home inn
set start_room "/d/snow/inn_hall"

# Opposite direction mapping for backtracking
array set opposite {
    north south
    south north
    east west
    west east
    northeast southwest
    southwest northeast
    northwest southeast
    southeast northwest
    up down
    down up
    enter out
    out enter
}

puts "\n=== Test: Room Connectivity (DFS Walk) ==="

if {$report_file ne ""} {
    init_report $report_file "02 - Room Connectivity (DFS Walk)"
}

# --------------------------------------------------------------------------
# Parse room_paths.txt → build adjacency graph
# --------------------------------------------------------------------------
set data_file "$script_dir/../data/room_paths.txt"
if {![file exists $data_file]} {
    log_fail "Load room data" "File $data_file not found — run generate_test_data.sh first"
    close_report
    exit 1
}

set fh [open $data_file r]
set room_data [read $fh]
close $fh

# graph(room,dir) = destination room
# exits_list(room) = list of {dir dest} pairs
array set graph {}
array set exits_list {}
set all_rooms {}

foreach line [split $room_data "\n"] {
    set line [string trim $line]
    if {$line eq "" || [string index $line 0] eq "#"} continue
    set parts [split $line "\t"]
    if {[llength $parts] >= 3} {
        set src [lindex $parts 0]
        set dir [lindex $parts 1]
        set dest [lindex $parts 2]

        set graph($src,$dir) $dest

        if {![info exists exits_list($src)]} {
            set exits_list($src) {}
        }
        lappend exits_list($src) [list $dir $dest]

        # Track all rooms mentioned in the data
        if {[lsearch -exact $all_rooms $src] == -1} {
            lappend all_rooms $src
        }
        if {[lsearch -exact $all_rooms $dest] == -1} {
            lappend all_rooms $dest
        }
    }
}

set total_rooms [llength $all_rooms]
set total_exits [array size graph]
puts "Loaded graph: $total_rooms rooms, $total_exits exits"

# --------------------------------------------------------------------------
# Parse hidden_paths.txt → add action-based exits to graph
# --------------------------------------------------------------------------
# Format: source_room	action_command	destination_room	reverse_command
# These exits use add_action() and aren't in room_paths.txt.
array set reverse_cmd {}

set hidden_file "$script_dir/../data/hidden_paths.txt"
if {[file exists $hidden_file]} {
    set fh [open $hidden_file r]
    set hidden_data [read $fh]
    close $fh

    set hidden_count 0
    foreach line [split $hidden_data "\n"] {
        set line [string trim $line]
        if {$line eq "" || [string index $line 0] eq "#"} continue
        set parts [split $line "\t"]
        if {[llength $parts] >= 4} {
            set src [lindex $parts 0]
            set action [lindex $parts 1]
            set dest [lindex $parts 2]
            set rev [lindex $parts 3]

            set graph($src,$action) $dest
            if {![info exists exits_list($src)]} {
                set exits_list($src) {}
            }
            lappend exits_list($src) [list $action $dest]

            # Store the explicit reverse command for backtracking
            set reverse_cmd($src,$action) $rev

            if {[lsearch -exact $all_rooms $src] == -1} { lappend all_rooms $src }
            if {[lsearch -exact $all_rooms $dest] == -1} { lappend all_rooms $dest }
            incr hidden_count
        }
    }

    set total_rooms [llength $all_rooms]
    puts "Loaded $hidden_count hidden/action-based exits"
    puts "Total graph: $total_rooms rooms"
}

# --------------------------------------------------------------------------
# Login
# --------------------------------------------------------------------------
if {![mud_login $host $port $test_user $test_pass]} {
    log_fail "Login" "Could not login for room walk test"
    close_report
    exit 1
}
log_pass "Login for room walk"

# Verify we're at the starting room
set output [mud_cmd "look"]

# --------------------------------------------------------------------------
# Iterative DFS walk
# --------------------------------------------------------------------------
# Stack entries: {room exit_index backtrack_dir}
#   room: current room path
#   exit_index: next exit index to try from this room
#   backtrack_dir: direction to send to return to parent (empty for start)

array set visited {}
set visited($start_room) 1
set rooms_visited 1
set exits_tested 0
set exits_passed 0
set exits_broken 0
set broken_exits_list {}

# Stack: list of {room exit_index backtrack_dir}
set stack [list [list $start_room 0 ""]]

puts "\nStarting DFS from $start_room ..."

while {[llength $stack] > 0} {
    # Peek at top of stack
    set top_idx [expr {[llength $stack] - 1}]
    set top [lindex $stack $top_idx]
    set room [lindex $top 0]
    set idx [lindex $top 1]
    set backtrack [lindex $top 2]

    # Get exits for this room
    if {[info exists exits_list($room)]} {
        set room_exits $exits_list($room)
    } else {
        set room_exits {}
    }

    if {$idx >= [llength $room_exits]} {
        # All exits from this room explored — backtrack
        set stack [lreplace $stack $top_idx $top_idx]

        if {$backtrack ne ""} {
            # Walk back to parent
            set bt_output [mud_cmd "$backtrack"]
            after 500

            # Check if backtrack worked
            if {[string match "*沒有這個方向*" $bt_output] || [string match "*沒有出路*" $bt_output] || [string match "*什麼*" $bt_output]} {
                log_warn "Backtrack: $room via $backtrack" "Could not backtrack — DFS may be out of sync"
            }
        }
        continue
    }

    # Advance the exit index for this stack entry
    set new_top [list $room [expr {$idx + 1}] $backtrack]
    set stack [lreplace $stack $top_idx $top_idx $new_top]

    # Get the exit to try
    set exit_info [lindex $room_exits $idx]
    set dir [lindex $exit_info 0]
    set dest [lindex $exit_info 1]

    # Skip if destination already visited
    if {[info exists visited($dest)]} {
        continue
    }

    # Try walking in this direction
    incr exits_tested
    set output [mud_cmd "$dir"]
    after 500

    # Check for errors
    if {[string match "*沒有這個方向*" $output] || [string match "*沒有出路*" $output] || [string match "*什麼*" $output]} {
        log_fail "Exit: $room → $dir → $dest" "Exit does not work"
        incr exits_broken
        lappend broken_exits_list "$room → $dir → $dest"
        # Don't recurse — we didn't actually move
        continue
    }

    # Check for timeout/eof
    if {$output eq "TIMEOUT" || $output eq "EOF"} {
        log_warn "Exit: $room → $dir → $dest" "Command timed out or connection lost"
        continue
    }

    # Success — we moved to dest
    log_pass "Exit: $room → $dir → $dest"
    incr exits_passed
    set visited($dest) 1
    incr rooms_visited

    # Compute backtrack direction — use explicit reverse_cmd if available
    if {[info exists reverse_cmd($room,$dir)]} {
        set back_dir $reverse_cmd($room,$dir)
    } elseif {[info exists opposite($dir)]} {
        set back_dir $opposite($dir)
    } else {
        set back_dir ""
    }

    # Push new room onto stack
    lappend stack [list $dest 0 $back_dir]
}

# --------------------------------------------------------------------------
# Report unreachable rooms
# --------------------------------------------------------------------------
set unreachable {}
foreach room $all_rooms {
    if {![info exists visited($room)]} {
        lappend unreachable $room
    }
}

if {[llength $unreachable] > 0} {
    puts "\n--- Unreachable Rooms ([llength $unreachable]) ---"
    foreach room $unreachable {
        puts "  UNREACHABLE: $room"
        log_warn "Unreachable: $room" "No path from $start_room"
    }
}

if {[llength $broken_exits_list] > 0} {
    puts "\n--- Broken Exits ($exits_broken) ---"
    foreach exit_str $broken_exits_list {
        puts "  BROKEN: $exit_str"
    }
}

# --------------------------------------------------------------------------
# Summary
# --------------------------------------------------------------------------
puts "\n--- Summary ---"
puts "  Rooms visited: $rooms_visited / $total_rooms"
puts "  Exits tested:  $exits_tested"
puts "  Exits passed:  $exits_passed"
puts "  Exits broken:  $exits_broken"
puts "  Unreachable:   [llength $unreachable]"

mud_logout

puts "\n=== Room Walk Test Complete: [get_test_summary] ==="

close_report
exit [get_fail_count]
