  "mythology": {
    "creation": "盤古開天闢地，分為人界與混沌界。天神與侮天鬼分治。寒於為天朝第一統治者，獲神器寶袍及穿靈、旋芒雙刃。5000年前寒於斬侮天鬼頭顱，17日大戰後力竭而亡。其靈魂化為十三靈：金烏(日)、銀蟾(月)、風、雨、雷、火、山、林、川、原、天、地之靈。300年前封印破裂，侮天鬼重現。",
    "thirteen_spirits": ["金烏(日)", "銀蟾(月)", "風靈", "雨靈", "雷靈", "火靈", "山靈", "林靈", "川靈", "原靈", "天靈", "地靈"],
    "timeline": [
      "5000年前：寒於斬侮天鬼",
      "1000年前：無遲氏族長商句征服沿岔河地區，建立金烏圖騰國",
      "994年前：於蘭攸嫁君達，建立天朝",
      "300年前：聖木被毀，封印破裂",
      "124年前：武貞帝登基",
      "48年前：至賢帝登基",
      "30年前：佑聖帝登基"
    ]
  },
